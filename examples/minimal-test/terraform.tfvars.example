# Minimal Test Configuration
# Copy this file to terraform.tfvars and fill in your values

# Required: Last9 credentials
last9_org = "your-org-name"
last9_refresh_token = "your-refresh-token"

# Required: Entity for testing
entity_name = "your-entity-name"

# Optional: Custom API URL (defaults to https://api.last9.io)
# last9_api_base_url = "https://api.last9.io"

# Optional: Region (defaults to us-west-2)
# region = "us-west-2"